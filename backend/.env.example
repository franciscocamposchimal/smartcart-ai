# App
NODE_ENV=development
PORT=3000

# Database (Supabase PostgreSQL)
# TODO: Replace with your Supabase project credentials
DB_HOST=db.your-project-ref.supabase.co
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=your-supabase-db-password
DB_DATABASE=postgres
DB_SSL=true

# Supabase (Auth)
# TODO: Get from https://app.supabase.com/project/_/settings/api
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# JWT
# TODO: Use a strong random secret in production
JWT_SECRET=your-jwt-secret-change-in-production
JWT_EXPIRATION=7d

# Google Gemini LLM
# TODO: Get from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-1.5-flash

# Frontend (path to built frontend dist for static serving)
FRONTEND_DIST_PATH=../frontend/dist
